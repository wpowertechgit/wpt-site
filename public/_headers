/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://www.google.com https://maps.gstatic.com https://*.googleapis.com https://i.ytimg.com; font-src 'self' data:; connect-src 'self' https://api.wpowertech.ro https://maps.googleapis.com https://maps.gstatic.com; frame-src https://www.google.com https://www.youtube-nocookie.com; form-action 'self' https://api.wpowertech.ro; media-src 'self'; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests; block-all-mixed-content
