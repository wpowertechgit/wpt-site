    "@tailwindcss/postcss": "^4.1.18",
    "framer-motion": "^12.34.0",
    "maath": "^0.10.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.0",
    "react-vertical-timeline-component": "^4.0.0"
